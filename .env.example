# The real production domain. Anything else gets noindex.
NEXT_PUBLIC_PRODUCTION_HOST=evolvedancecenter.com

# Canonical site URL (optional; defaults to https://evolvedancecenter.com)
NEXT_PUBLIC_SITE_URL=https://evolvedancecenter.com

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_WRITE_TOKEN=

# Jackrabbit Class
NEXT_PUBLIC_JACKRABBIT_ENROLL_URL=https://app.jackrabbitclass.com/regv2.asp?id=531584
JACKRABBIT_ORG_ID=

# Resend (contact + free trial forms)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Evolve Dance Center <noreply@evolvedancecenter.com>
EVOLVE_INBOX_EMAIL=info@evolvedancecenter.com

# Cloudflare Turnstile (optional in dev; required in production)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
